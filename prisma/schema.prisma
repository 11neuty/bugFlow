generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  QA
  DEVELOPER
}

enum ProjectRole {
  ADMIN
  QA
  DEVELOPER
  VIEWER
}

enum IssueStatus {
  TODO
  IN_PROGRESS
  DONE
  CLOSED
  REJECTED
}

enum IssuePriority {
  LOW
  MEDIUM
  HIGH
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditAction {
  ISSUE_CREATED
  STATUS_CHANGED
  ASSIGNED
  ASSIGNMENT_CHANGED
  PRIORITY_CHANGED
  COMMENT_ADDED
  ISSUE_DELETED
}

enum NotificationType {
  ISSUE_ASSIGNED
  ISSUE_COMMENTED
  ISSUE_STATUS_CHANGED
}

model Project {
  id        String   @id @default(uuid())
  name      String   @unique
  deletedAt DateTime?
  createdAt DateTime @default(now())
  issues    Issue[]
  members   ProjectMember[]

  @@index([createdAt])
  @@index([deletedAt])
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  password       String
  name           String
  role           Role           @default(DEVELOPER)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  assignedIssues Issue[]        @relation("IssueAssignee")
  reportedIssues Issue[]        @relation("IssueReporter")
  comments       Comment[]
  auditLogs      AuditLog[]
  notifications  Notification[]
  projectMembers ProjectMember[]
  refreshTokens  RefreshToken[]
}

model Issue {
  id          String         @id @default(cuid())
  issueNumber Int            @unique @default(autoincrement())
  title       String
  description String
  projectId   String
  status      IssueStatus    @default(TODO)
  priority    IssuePriority  @default(MEDIUM)
  severity    IssueSeverity  @default(MEDIUM)
  version     Int            @default(1)
  assigneeId  String?
  reporterId  String
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Restrict)
  assignee    User?          @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter    User           @relation("IssueReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  comments    Comment[]
  auditLogs   AuditLog[]
  notifications Notification[]

  @@index([projectId])
  @@index([projectId, status, createdAt])
  @@index([projectId, deletedAt, createdAt])
  @@index([status])
  @@index([priority])
  @@index([severity])
  @@index([issueNumber])
  @@index([assigneeId])
  @@index([reporterId])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([deletedAt])
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([projectId, role])
}

model Comment {
  id        String   @id @default(cuid())
  issueId   String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([userId])
  @@index([createdAt])
}

model AuditLog {
  id        String      @id @default(cuid())
  issueId   String
  action    AuditAction
  userId    String
  metadata  Json?
  createdAt DateTime    @default(now())
  issue     Issue       @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([userId])
  @@index([createdAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  issueId   String?
  type      NotificationType
  message   String
  dedupeKey String?          @unique
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  issue     Issue?           @relation(fields: [issueId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@index([createdAt])
  @@index([issueId])
}
